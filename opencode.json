{
  "$schema": "https://opencode.ai/config.json",
  "model": "fireworks-ai/kimi-k2p6",
  "permission": {
    "edit": "ask",
    "bash": "ask",
    "webfetch": "allow"
  },
  "permission": {
    "bash": {
      "*": "ask",
      "aws configure *": "ask",
      "aws ec2 describe-*": "allow",
      "aws ec2 terminate *": "ask",
      "aws eks describe-*": "allow",
      "aws iam *": "ask",
      "aws s3 ls *": "allow",
      "aws s3 rb *": "ask",
      "aws sts get-session-token *": "deny",
      "base64 *": "allow",
      "basename *": "allow",
      "brew info *": "allow",
      "brew install *": "ask",
      "brew list *": "allow",
      "brew uninstall *": "ask",
      "bun *": "allow",
      "cargo *": "allow",
      "cat *": "allow",
      "chmod -R 777 *": "deny",
      "clojure -M:*": "allow",
      "cmake *": "allow",
      "comm *": "allow",
      "curl *": "ask",
      "cut *": "allow",
      "dart *": "allow",
      "date": "allow",
      "dd *": "deny",
      "df *": "allow",
      "diff *": "allow",
      "dirname *": "allow",
      "docker build *": "allow",
      "docker cp *": "ask",
      "docker exec *": "ask",
      "docker login *": "deny",
      "docker logs *": "allow",
      "docker ps *": "allow",
      "docker rm *": "ask",
      "docker rmi *": "ask",
      "docker-compose down *": "ask",
      "docker-compose up -d *": "allow",
      "du *": "allow",
      "echo *": "allow",
      "env": "allow",
      "file *": "allow",
      "find *": "allow",
      "flutter *": "allow",
      "gh *": "allow",
      "git *": "allow",
      "gradle *": "allow",
      "grep *": "allow",
      "head *": "allow",
      "helm get *": "allow",
      "helm list *": "allow",
      "jq *": "allow",
      "kubectl config *": "ask",
      "kubectl cordon *": "ask",
      "kubectl delete *": "ask",
      "kubectl describe *": "allow",
      "kubectl drain *": "ask",
      "kubectl exec *": "ask",
      "kubectl get *": "allow",
      "kubectl logs *": "allow",
      "kubectl top *": "allow",
      "lein *": "allow",
      "ls *": "allow",
      "lsof *": "allow",
      "make *": "allow",
      "md5 *": "allow",
      "mkdir *": "allow",
      "mvn *": "allow",
      "nc *": "deny",
      "nmap *": "deny",
      "node *": "allow",
      "npm *": "allow",
      "npm login *": "deny",
      "npx *": "allow",
      "opencode *": "allow",
      "paste *": "allow",
      "pip install *": "ask",
      "pnpm *": "allow",
      "printenv *": "allow",
      "ps *": "allow",
      "pwd": "allow",
      "python -m http.server *": "allow",
      "readlink *": "allow",
      "realpath *": "allow",
      "rg *": "allow",
      "rm -rf /*": "deny",
      "shasum *": "allow",
      "sort *": "allow",
      "stat *": "allow",
      "sudo *": "deny",
      "sudo rm *": "deny",
      "sw_vers": "allow",
      "tail *": "allow",
      "terraform apply *": "ask",
      "terraform destroy *": "deny",
      "terraform plan *": "allow",
      "terraform show *": "allow",
      "terraform validate *": "allow",
      "timeout *": "allow",
      "tr *": "allow",
      "tree *": "allow",
      "uname *": "allow",
      "uniq *": "allow",
      "uv add *": "allow",
      "uv sync": "allow",
      "wc *": "allow",
      "which *": "allow",
      "yarn *": "allow"
    },
    "read": {
      "*": "allow",
      "~/.aws/credentials": "deny",
      "~/.aws/config": "deny",
      "~/.kube/config": "deny",
      "~/.ssh/*": "deny",
      "~/.git-credentials": "deny",
      "~/.npmrc": "deny",
      "~/.pypirc": "deny",
      "~/.docker/config.json": "deny",
      "**/credentials*": "deny",
      "**/secrets*": "deny",
      "**/*token*": "deny",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
      "~/Keys/*": "deny",
      "~/Keys/**/*": "deny"
    },
    "edit": {
      "*": "allow",
      "~/.aws/*": "deny",
      "~/.kube/*": "deny",
      "~/.ssh/*": "deny",
      "~/.zshrc": "ask",
      "~/.bashrc": "ask",
      "~/.gitconfig": "ask",
      "**/.env*": "deny",
      "~/.config/opencode/.env": "deny",
      "~/Keys/*": "deny",
      "~/Keys/**/*": "deny",
      "~/.config/opencode/opencode.json": "deny"
    },
    "emacs_eval-elisp": "allow",
    "emacs_edit_buffer_with_preview": "ask",
    "emacs_get_project_context": "allow",
    "emacs_get_project_structure": "allow",
    "emacs_get_open_buffers_with_symbols": "allow",
    "emacs_get_diagnostics_all": "allow",
    "emacs_find_definition": "allow",
    "emacs_find_references": "allow",
    "emacs_get_imenu_symbols": "allow",
    "emacs_get_tree_sitter_node": "allow",
    "emacs_get-diagnostics": "allow",
    "emacs_org-agenda": "allow",
    "emacs_org-search": "allow",
    "emacs_org-get-node": "allow",
    "emacs_org-list-templates": "allow",
    "emacs_org-list-tags": "allow",
    "emacs_org-capture": "ask",
    "emacs_org-update-node": "ask",
    "emacs_org-refile": "ask",
    "emacs_org-archive": "ask",
    "emacs_org-clock": "ask",
    "emacs_org-roam-search": "allow",
    "emacs_org-roam-get-node": "allow",
    "emacs_org-roam-capture": "ask",
    "emacs_edit_buffer_silent": "allow",
    "emacs_load_file": "allow"
  },
  "provider": {
    "fireworks-ai": {
      "models": {
        "kimi-k2p6": {
          "id": "accounts/fireworks/models/kimi-k2p6"
        },
        "qwen3p6-plus": {
          "id": "accounts/fireworks/models/qwen3p6-plus"
        },
        "minimax-m2p7": {
          "id": "accounts/fireworks/models/minimax-m2p7"
        },
        "deepseek-v4-pro": {
          "id": "accounts/fireworks/models/deepseek-v4-pro"
        }
      }
    },
    "amazon-bedrock": {
      "options": {
        "region": "us-east-1",
        "profile": "bedrock"
      },
      "models": {
        "moonshot.kimi-k2-thinking": {
          "modelId": "moonshot.kimi-k2-thinking"
        }
      }
    }
  },
  "agent": {
    "subagents": {
      "reviewer": {
        "model": "fireworks-ai/kimi-k2p6",
        "description": "Code review agent - checks code quality, style, and correctness"
      },
      "coder": {
      "model": "fireworks-ai/kimi-k2p6",
        "description": "Code implementation agent - writes and refactors Elisp code"
      },
      "tester": {
      "model": "fireworks-ai/kimi-k2p6",
        "description": "Test implementation and execution agent - writes ERT tests and runs them"
      }
    }
  }
}
